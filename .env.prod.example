# Пример окружения для docker-compose.prod.yml
# Скопируйте: cp .env.prod.example .env
# Правьте значения и НЕ коммитьте .env в Git.

# --- Обязательно в продакшене ---
POSTGRES_PASSWORD=abzaydin2003

JWT_SECRET=сгенерируйте-длинную-случайную-строку
BOT_INTERNAL_SECRET=ещё-одна-длинная-случайная-строка

TELEGRAM_BOT_TOKEN=от-BotFather
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=MyShopBot
ADMIN_TELEGRAM_IDS=ваш_telegram_user_id
ADMIN_CHAT_ID=id_чата_для_уведомлений_админу

# Публичный URL фронта (Telegram Mini App, кнопки бота)
MINI_APP_URL=https://mebelhub05.ru

# Домен, на который указывает DNS (без схемы) — для Caddy и TLS
PRIMARY_DOMAIN=mebelhub05.ru

# URL API с точки зрения браузера (должен совпадать с тем, что проксирует Caddy)
# Один домен, API по пути /api:
NEXT_PUBLIC_API_URL=https://mebelhub05.ru/api
CORS_ORIGINS=https://mebelhub05.ru

# Если используете caddy/Caddyfile.subdomain, задайте API_DOMAIN и другой URL API:
# API_DOMAIN=api.shop.example.com
# NEXT_PUBLIC_API_URL=https://api.shop.example.com/api
# CORS_ORIGINS=https://shop.example.com

# Какой Caddyfile монтировать (по умолчанию — Let's Encrypt на PRIMARY_DOMAIN)
# CADDYFILE=./caddy/Caddyfile
# Локальный тест TLS без публичного DNS:
# CADDYFILE=./caddy/Caddyfile.selfsigned
